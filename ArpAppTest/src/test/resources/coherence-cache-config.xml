<?xml version="1.0"?>
<!DOCTYPE cache-config SYSTEM "cache-config.dtd">

<cache-config>
	<caching-scheme-mapping>
		<cache-mapping>
			<cache-name>AuthCache</cache-name>
			<scheme-name>DistributedAuthorizationCacheScheme</scheme-name>
		</cache-mapping>
		<cache-mapping>
			<cache-name>*</cache-name>
			<scheme-name>eclipselink-distributed-gridcache</scheme-name>
		</cache-mapping>
	</caching-scheme-mapping>
	<caching-schemes>
		<distributed-scheme>
			<scheme-name>eclipselink-distributed-gridcache</scheme-name>
			<service-name>EclipseLinkJPAGridCache</service-name>
			<!-- Configure a wrapper serializer to support serialization of relationships. -->
			<serializer id="arp-pof">
			      <class-name>com.tangosol.io.pof.ConfigurablePofContext</class-name>
			      <init-params>
			         <init-param>
			            <param-type>String</param-type>
			            <param-value>arp-pof-config.xml</param-value>
			         </init-param>
			      </init-params>
			</serializer>
			<backing-map-scheme>
				<local-scheme>
					<scheme-ref>unlimited-backing-map</scheme-ref>
				</local-scheme>
			</backing-map-scheme>
			<autostart>true</autostart>
			<backup-count>0</backup-count>
		</distributed-scheme>
		
		<distributed-scheme>
			<scheme-name>DistributedAuthorizationCacheScheme</scheme-name>
			<service-name>DistributedAuthCache</service-name>
			<backing-map-scheme>
				<local-scheme>
					<scheme-name>DistributedAuthMap</scheme-name>
					<eviction-policy>LRU</eviction-policy>
					<high-units>30</high-units>
          				<!-- 30 MB for nonprd -->
          				<unit-calculator>BINARY</unit-calculator>
          				<expiry-delay>1024</expiry-delay>
          				<!-- 86400 sec 1 day -->
          				<cachestore-scheme/>
          				<unit-factor>1048576</unit-factor>
          				<!-- 1MB -->
          			</local-scheme>	
      			</backing-map-scheme>
      			<autostart>true</autostart>
      		</distributed-scheme>
      		
		<local-scheme>
			<scheme-name>unlimited-backing-map</scheme-name>
		</local-scheme>
	</caching-schemes>
</cache-config>