<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans.dtd">
<beans>

	<bean name="tirDomain"
		class="com.oocl.frm.tir.configuration.IndexDomain">
		<property name="analyzer" ref="sizableNGramFuzzyAnalyzer" />
		<property name="indexStore" ref="tirStore" />		
	</bean>

	<bean name="sizableNGramFuzzyAnalyzer"
		class="com.oocl.frm.tir.index.analyzer.SizableNGramTokenAnalyzer" singleton="false">
		<property name="tokenSizes">
			<list>
				<value>1</value>
				<value>4</value>
				<value>9</value>
			</list>
		</property>
	</bean>

	<bean name="tirStore"
		class="com.oocl.frm.tir.store.impl.FSIndexStore">
		<property name="location" value="D:/ToShare/arp-iris4/ARP_APP_Server/tir_index"></property>
		<property name="resourceTypes">
			<list>
				<value>INVOICE</value>
				<value>PAYMENT</value>
				<value>INVOICE_MATCHING</value>
			</list>
		</property>
	</bean>

</beans>