	</bean>
	
	<bean id="transactionSummaryOpenService"
		class="com.oocl.ir4.arp.openservice.transactionsummary.impl.DefaultTransactionSummaryOpenService">
		<property name="transationSummaryService" ref="transactionSummaryService" />
