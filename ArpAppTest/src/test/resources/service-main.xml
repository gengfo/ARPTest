	xmlns:tx="http://www.springframework.org/schema/tx"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
	http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop-2.0.xsd
	http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx-2.0.xsd">

	<bean id="paymentOpenService"
		class="com.oocl.ir4.arp.openservice.payment.impl.DefaultPaymentOpenService">
		<property name="invoiceService" ref="invoiceService" />
		<property name="paymentService" ref="paymentService" />
		<property name="exchangeRateService" ref="exchangeRateService"></property>
		<property name="invoiceAdjustmentService" ref="invAdjService"/>
		<property name="sequenceNumberService" ref="sequenceNumberService" />
		<property name="paymentTransferService" ref="paymentTransferService" />
		<property name="ruleService" ref="ruleService" />
		<property name="suppDataService" ref="suppDataService" />
		<property name="currencyService" ref="currencyService" />
		<property name="userPreferenceService" ref="userPreferenceService" />
		<property name="organizationService" ref="orgService" />
		<property name="paymentInstructionService" ref="paymentInstructionService" />
		<property name="auditTrailService" ref="auditTrailService" />
	</bean>

	<bean id="invoiceOpenService"
		class="com.oocl.ir4.arp.openservice.invoice.impl.DefaultInvoiceOpenService">
		<property name="invoiceService" ref="invoiceService" />
		<property name="ruleService" ref="ruleService"/>
		<property name="currencyService" ref="currencyService" />
		<property name="invoiceDocService" ref="invoiceDocService"/>
		<property name="orgService" ref="orgService" />
		<property name="customerService" ref="customerService" />
		<property name="interfaceTaskService" ref="interfaceTaskService" />
		<property name="auditTrailService" ref="auditTrailService" />
		<property name="csInterfaceService" ref="cargoSmartInterfaceService"/>
	</bean>
	
	<bean id="ruleOpenService"
		class="com.oocl.ir4.arp.openservice.rule.impl.DefaultRuleOpenService">
		<property name="ruleService" ref="ruleService" />
		<property name="orgService" ref="orgService" />
	</bean>
	<bean id="suppDataOpenService"
		class="com.oocl.ir4.arp.openservice.suppdata.impl.DefaultSuppDataOpenService">
		<property name="chargeCodeService" ref="chargeCodeService" />
		<property name="suppDataService" ref="suppDataService" />
		<property name="userPreferenceService" ref="userPreferenceService" />
		<property name="organizationService" ref="orgService" />
	</bean>
	
	<bean id="organizationOpenService"
		class="com.oocl.ir4.arp.openservice.suppdata.impl.DefaultOrganizationOpenService">
		<property name="organizationService" ref="orgService" />
	</bean>
	
	<bean id="invAdjOpenService" class="com.oocl.ir4.arp.openservice.invadj.impl.DefaultInvoiceAdjustmentOpenService">
		
		<property name="invAdjService" ref="invAdjService" />
		<property name="invoiceService" ref="invoiceService" />
		<property name="exchangeRateService" ref="exchangeRateService" />
		<property name="currencyService" ref="currencyService"></property>
		<property name="sequenceNumberService" ref="sequenceNumberService"></property>
		<property name="auditTrailService" ref="auditTrailService"></property>
	</bean>
	<bean id="paymentTransferOpenService" class="com.oocl.ir4.arp.openservice.paymenttransfer.impl.DefaultPaymentTransferOpenService">

		<property name="invoiceService" ref="invoiceService" /> 
		<property name="paymentTransferService" ref="paymentTransferService" /> 
		<property name="exrateService" ref="exchangeRateService" />
		<property name="invAdjService" ref="invAdjService"/> 
		<property name="paymentService" ref="paymentService" />
		<property name="sequenceNumberService" ref="sequenceNumberService" />
