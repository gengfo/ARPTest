	</bean>
	
	<bean id="authorityOpenService" class="com.oocl.ir4.arp.openservice.common.interceptor.auth.impl.DefaultAuthorityOpenService">
		<property name="organizationService" ref="orgService" />
	</bean>
	
	<bean id="tirOpenService" class="com.oocl.ir4.arp.openservice.tir.impl.DefaultTIROpenService" >
		<property name="tirService" ref="tirService" />
		<property name="invoiceService" ref="invoiceService" />
		<property name="paymentService" ref="paymentService" />
		<property name="invoiceMatchingService" ref="invoiceMatchingService" />
		<property name="suppDataService" ref="suppDataService" />
		<property name="currencyService" ref="currencyService"/>
	</bean>
	
	<bean id="auditTrailOpenService" class="com.oocl.ir4.arp.openservice.audit.impl.DefaultAuditTrailOpenService" >
		<property name="auditTrailService" ref="auditTrailService" />
		<property name="invoiceMatchingService" ref="invoiceMatchingService" />
		<property name="invoiceService" ref="invoiceService" />
		<property name="paymentService" ref="paymentService" />
		<property name="organizationService" ref="orgService" />
	</bean>
	
	<bean id="jobcostOpenService" class="com.oocl.ir4.arp.openservice.jobcost.impl.DefaultJobCostOpenService" >
		<property name="invoiceMatchingService" ref="invoiceMatchingService" />
		<property name="currencyService" ref="currencyService"/>
	</bean>
	
	<bean id="analyzeOutstandingBalanceOpenService" class="com.oocl.ir4.arp.openservice.report.impl.DefaultAnalyzeOutstandingBalanceOpenService" >
		<property name="ostBalService" ref="outstandingBalanceService" />
	</bean>
	
	<bean id="rejectedEDIInvOpenService" class="com.oocl.ir4.arp.openservice.edi.impl.DefaultRejEDIInvMatchOpenService">
		<property name="rejEDIInvoiceService" ref="rejEDIInvService" />
		<!--property name="suppDataService" ref="suppDataService" /-->
	</bean>
    
	<bean id="ediHistoryOpenService" class="com.oocl.ir4.arp.openservice.edi.impl.DefaultEDIHistoryOpenService">
		<property name="ediHistoryService" ref="ediHistoryService" />
		<property name="ediInvMatchProcessor" ref="ediInvMatchProcessor" />
	</bean>
	
	<bean id="jobOpenService" class="com.oocl.ir4.arp.openservice.lts.impl.DefaultJobOpenService">
		<property name="jobService" ref="jobService" />
	</bean>
	
	<bean id="paymentInstructionOpenService" class="com.oocl.ir4.arp.openservice.paymentinstruction.impl.DefaultPaymentInstructionOpenService">
		<property name="paymentInstructionService" ref="paymentInstructionService" />
	</bean>	
	
	<bean id="mockUiOpenService" class="com.oocl.ir4.arp.openservice.mockui.impl.DefaultMockUIOpenservice">
	</bean>	
	
	<bean id="shipmentOpenService" class="com.oocl.ir4.arp.openservice.shipment.impl.DefaultShipmentOpenService">
		<property name="bLService" ref="bLService" />    
	</bean>
	
	<bean id="officeOpenService" class="com.oocl.ir4.arp.openservice.office.impl.DefaultOfficeOpenService">
		<property name="orgService" ref="orgService" />    
		<property name="ruleService" ref="ruleService" />  
	</bean>

