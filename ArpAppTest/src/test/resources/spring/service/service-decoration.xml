<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:aop="http://www.springframework.org/schema/aop"
 xmlns:tx="http://www.springframework.org/schema/tx"
 xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.0.xsd
 http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop-2.0.xsd
 http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx-2.0.xsd ">

<!-- the transactional advice (i.e. what 'happens'; see the <aop:advisor/>
bean below) -->
<tx:advice id="txAdvice" transaction-manager="txManager">
    <!-- the transactional semantics... -->
    <tx:attributes>
        <!-- all methods starting with 'get' are read-only -->
        <tx:method name="search*" read-only="true"/>
        <tx:method name="find*" read-only="true"/>
        <tx:method name="get*" read-only="true"/>
        <tx:method name="work*" read-only="true"/>
		<tx:method name="create*" read-only="false"/>
        <tx:method name="ltsAuto*" read-only="false"/>
        <!-- other methods use the default transaction settings (see below) -->
        <tx:method name="*"/>
    </tx:attributes>
</tx:advice>

<!-- ensure that the above transactional advice runs for any execution of
an operation defined by the FooService interface -->
<aop:config>
    <aop:pointcut id="serviceOperation"
      expression="(within(com.oocl.ir4.arp.openservice..*) || within(com.oocl.ir4.arp.web.common.download.*)|| execution(* ltsAuto*(..)))  and !execution(* com.oocl.ir4.arp.openservice.edi.RejEDIInvMatchOpenService.reprocessEDIInv(..))"/>
   <aop:advisor advice-ref="exceptionHandler" pointcut-ref="serviceOperation"/>
    <aop:advisor advice-ref="txAdvice" pointcut-ref="serviceOperation"/>
    <aop:advisor advice-ref="authAdvisor" pointcut-ref="serviceOperation"/>
</aop:config>

<aop:config>
    <aop:pointcut id="specialServiceOperation"
     expression="execution(* com.oocl.ir4.arp.openservice.edi.RejEDIInvMatchOpenService.reprocessEDIInv(..))"/>
    <aop:advisor advice-ref="exceptionHandler" pointcut-ref="specialServiceOperation"/>
	<aop:advisor advice-ref="authAdvisor" pointcut-ref="specialServiceOperation"/>
</aop:config>

<aop:config>
    <aop:pointcut id="artOperation"
     expression="execution(* com.oocl.ir4.arp.openservice.invoice.impl.*.*(..)) ||execution(* com.oocl.ir4.arp.openservice.invadj.impl.*.*(..)) ||execution(* com.oocl.ir4.arp.openservice.payment.impl.*.*(..)) ||execution(* com.oocl.ir4.arp.openservice.rule.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.invoicematching.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.edi.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.jobcost.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.paymenttransfer.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.tir.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.lts.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.audit.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.customer.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.eqm.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.exchangerate.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.shipment.impl.*.*(..))||execution(* com.oocl.ir4.arp.openservice.suppdata.impl.*.*(..))"/>
    <aop:advisor advice-ref="artAdvisor" pointcut-ref="artOperation"/>
</aop:config>
 
 <!-- 
 <aop:config>
    <aop:pointcut id="artOperation"
     expression="execution(* com.oocl.ir4.arp.openservice.*.*(..)) "/>
    <aop:advisor advice-ref="artAdvisor" pointcut-ref="artOperation"/>
</aop:config>
 -->

<bean id="performanceAdvisor"
 class="org.springframework.aop.interceptor.PerformanceMonitorInterceptor"/>

<bean id="artAdvisor"
 class="com.oocl.ir4.arp.openservice.common.interceptor.ARTRecorder"/>

<bean id="exceptionHandler"
 class="com.oocl.ir4.arp.openservice.common.interceptor.OpenServiceExceptionHandler"/>

<bean id="appContextHolder" class="com.oocl.ir4.arp.frm.spring.ApplicationContextHolder"/>

<bean id="authAdvisor"
 class="com.oocl.ir4.arp.openservice.common.interceptor.auth.AuthorityInterceptor"/>

</beans>
