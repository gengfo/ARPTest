<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    
<!--
    <import resource="../service/service-main.xml"/>
    -->
    
    <bean id="invoiceMatchingController"
     class="com.oocl.ir4.arp.web.invoicematching.controller.InvoiceMatchingController">
        <property name="invoiceMatchingOpenService" ref="invoiceMatchingOpenService"/>
    </bean>
    <bean id="SearchSPInvoiceController" class="com.oocl.ir4.arp.web.invoicematching.controller.SearchSPInvoiceController">
    	<property name="invMatchingOpenService" ref="invoiceMatchingOpenService" />
    </bean>
    <bean id="ediHistoryController" class="com.oocl.ir4.arp.web.edi.EDIHistoryController">
    	<property name="ediHistoryOpenService" ref="ediHistoryOpenService" />
    </bean>
    <bean id="SearchRejectedEDIInvoiceController" class="com.oocl.ir4.arp.web.invoicematching.controller.SearchRejectedEDIInvoiceController">
    	<property name="rejectedEDIInvOpenService" ref="rejectedEDIInvOpenService" />
    </bean>
    
	 <bean id="RejEDIInvMatchController" class="com.oocl.ir4.arp.web.edi.RejEDIInvMatchController">
    	<property name="rejectedEDIInvOpenService" ref="rejectedEDIInvOpenService" />
    </bean>
</beans>
