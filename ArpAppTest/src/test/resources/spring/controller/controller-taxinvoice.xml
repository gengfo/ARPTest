<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="taxInvoiceNumRangeController"
		class="com.oocl.ir4.arp.web.taxinvoicenum.controller.TaxInvoiceNumRangeController">
		<property name="taxInvoiceNumRangeOpenService" ref="taxInvoiceNumRangeOpenService" />
	</bean>

	<bean id="searchCITRateController"
		class="com.oocl.ir4.arp.web.citrate.controller.SearchCITRateController">
		<property name="citRateOpenService" ref="citRateOpenService" />
	</bean>

	<bean id="saveCITRateController"
		class="com.oocl.ir4.arp.web.citrate.controller.SaveCITRateController">
		<property name="citRateOpenService" ref="citRateOpenService" />
	</bean>

	<bean id="taxInvController" class="com.oocl.ir4.arp.web.taxinvoice.controler.TaxInvoiceController">
		<property name="taxInvoiceOpenService" ref="taxInvoiceOpenService"/>
	</bean>
</beans>
