<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    
    <bean id="cargoSmartInterfaceService" class="com.oocl.ir4.arp.service.cargosmartinterface.impl.DefaultCargoSmartInterfaceService">
       <property name="invoiceService" ref="invoiceService" />
       <property name="interfaceTaskService" ref="interfaceTaskService"/>
       <property name="ruleService" ref="ruleService" />
       <property name="auditTrailService" ref="auditTrailService" />
       <property name="sequenceNumberService" ref="sequenceNumberService" />
       <property name="paymentService" ref="paymentService" />
       <property name="invoiceDocService" ref="invoiceDocService" />
       <property name="organizationService" ref="orgService"/>
       <property name="suppDataService" ref="suppDataService"/>
    </bean>	    
    
    <bean id="invPropertyListener" class="com.oocl.ir4.arp.service.invoice.InvPropertyListener">
		<property name="csInterfaceService" ref="cargoSmartInterfaceService" />    
	</bean>		
	<bean id="cSInvoiceAuditInfoProcessor" class="com.oocl.ir4.arp.service.cargosmartinterface.impl.CSInvoiceAuditInfoProcessor">
		<property name="cargoSmartInterfaceService" ref="cargoSmartInterfaceService" />    
	</bean>	
	<bean id="cSInvoicePDFProcessor" class="com.oocl.ir4.arp.service.cargosmartinterface.impl.CSInvoicePDFProcessor">
		<property name="cargoSmartInterfaceService" ref="cargoSmartInterfaceService" />    
	</bean>	
	<bean id="cSInvoiceDataProcessor" class="com.oocl.ir4.arp.service.cargosmartinterface.impl.CSInvoiceDataProcessor">
		<property name="cargoSmartInterfaceService" ref="cargoSmartInterfaceService" />    
	</bean>	
	<bean id="invoiceRequestMsgReceiver" class="com.oocl.ir4.arp.csinterface.mif.receiver.InvoiceRequestMsgReceiver">
		<property name="cargoSmartInterfaceService" ref="cargoSmartInterfaceService" />    
	</bean>
	
</beans>
