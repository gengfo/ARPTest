	<session xsi:type="server-session">
		<name>bpfClientSession</name>
		<!-- It will cause "Commit Failed" exception, so remove this property -->
		<!-- <server-platform xsi:type="weblogic-10-platform"/> -->
		<event-listener-classes />
		<primary-project xsi:type="xml">bpfTopLinkProject.xml</primary-project>
		<login xsi:type="database-login">
			<platform-class>oracle.toplink.platform.database.oracle.Oracle11Platform</platform-class>
			<external-connection-pooling>true</external-connection-pooling>
			<external-transaction-controller>true</external-transaction-controller>
			<sequencing>
				<default-sequence xsi:type="native-sequence">
					<name>Native</name>
				</default-sequence>
			</sequencing>
			<datasource>bpfClientDataSource</datasource>
			<bind-all-parameters>true</bind-all-parameters>
			<cache-all-statements>true</cache-all-statements>
			<force-field-names-to-upper-case>true</force-field-names-to-upper-case>
			<jdbc-batch-writing>true</jdbc-batch-writing>
			<native-sql>true</native-sql>
		</login>
		<connection-pools>
			<read-connection-pool>
				<name>ReadConnectionPool</name>
			</read-connection-pool>
			<write-connection-pool>
				<name>default</name>
			</write-connection-pool>
		</connection-pools>
		<connection-policy />
	</session>
   
