<?xml version="1.0" ?>
<Component>

    <subcomponent name="persistenceGeneral" class="com.oocl.frm.persistence.configuration.FrmPersistenceGeneralConfigComponent">
        <var name="PERSISTENT_UNIT_JNDI_NAME" value="persistence/PFWTestPU" />
        <var name="DIAGNOSTIC_LOGGER_NAME" value="pfwDiagnosticLogger" />
        <var name="DEBUG_LOGGER_NAME" value="pfwDebugLogger" />
        <var name="MSG_LOGGER_NAME" value="pfwMsgLogger" />		
        <var name="DEBUG_LOGGING_ENABLED" value="true" />
        <!-- PERSISTENT_UNIT_NAME is used when running in standalone mode -->
        <!-- it should be the same as that configured in persistence.xml, <persistence-unit> -->
        <!-- can be omitted if STANDALONE_MODE is false -->
        <var name="PERSISTENT_UNIT_NAME" value="ARPUT"/>
        <!-- Set STANDALONE_MODE to true if testing in standalone program; false or omitted if running in WebLogic -->
        <!-- Default is false -->
        <var name="STANDALONE_MODE" value="true" />
    </subcomponent>

    <subcomponent name="pfwDebugLogger" class="com.oocl.csc.frm.integration.debug.logger.impl.FWDebugLoggerSubConfigComponent">
        <var name="LOG_ENABLED" value="true" />
        <var name="LOGGER_CLASS_NAME" value="com.oocl.csc.frm.integration.debug.logger.impl.FWDefaultDebugLogger" />
        <var name="LOGGER_SPECIFIC_PROPERTIES_FILE" value="" />
    </subcomponent>

    <subcomponent name="pfwMsgLogger" class="com.oocl.csc.frm.integration.logger.impl.FWLoggerSubConfigComponent">
        <var name="LOG_ENABLED" value="true" />
        <var name="FORCED_FATAL" value="true" />
        <var name="LOG_ERROR" value="true" />
        <var name="LOG_FATAL" value="true" />
        <var name="LOG_INFO" value="true" />
        <var name="LOG_WARNING" value="true" />
        <var name="LOG_DEBUG" value="true" />
        <var name="LOGGER_SPECIFIC_PROPERTIES_FILE" value="" />
    </subcomponent>

</Component>
