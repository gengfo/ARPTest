<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    
    <bean id="interfaceTaskDao" class="com.oocl.ir4.arp.dao.backendtask.impl.JpaInterfaceTaskDao">
    </bean>
    
    <bean id="bpfService" class="com.oocl.ir4.arp.service.bpf.DefaultBPFService">
    </bean>
    
    <bean id="interfaceTaskService" class="com.oocl.ir4.arp.service.appinterface.DefaultInterfaceTaskService">
        <property name="taskDao" ref="interfaceTaskDao"/>
        <property name="bpfService" ref="bpfService"/>
    </bean>
    
	<bean id="fodeService" class="com.oocl.ir4.arp.service.appinterface.DefaultFODEService">
        <property name="taskService" ref="interfaceTaskService"/>
        <property name="invDocService" ref="invoiceDocService"/>
		<property name="paymentService" ref="paymentService"/>
		<property name="mailService" ref="mailService" />
    </bean>
	
	<bean id="mcciService" class="com.oocl.ir4.arp.service.appinterface.DefaultMCCIService">
        <property name="taskService" ref="interfaceTaskService"/>
		<property name="invoiceService" ref="invoiceService"/>
    </bean>
</beans>
