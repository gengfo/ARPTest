<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    
	<!--
		<import resource="domain-context.xml" />
		-->
	<import resource="biz-suppdata-context.xml"/>
	<import resource="biz-rule-context.xml"/>
	
	<bean id="paymentDao" class="com.oocl.ir4.arp.dao.payment.impl.JpaPaymentDao">
	</bean>
    
	<bean id="paymentService" class="com.oocl.ir4.arp.service.payment.impl.DefaultPaymentService">
		<property name="paymentDao" ref="paymentDao"/>
		<property name="currencyService" ref="currencyService" />
		<property name="ruleService" ref="ruleService" />
		<property name="exchangeRateService" ref="exchangeRateService" />
		<property name="interfaceTaskService" ref="interfaceTaskService" />
	</bean>
	
	<bean id="receiptService" class="com.oocl.ir4.arp.service.payment.impl.DefaultReceiptService">
		<property name="currencyService" ref="currencyService" />
		<property name="ruleService" ref="ruleService" />
		<property name="paymentService" ref="paymentService" />
	</bean>
	
</beans>
