<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">

    <xsd:annotation>
        <xsd:documentation>This is the top element of bpfEmailNotificationConfig.xml</xsd:documentation>
    </xsd:annotation>

	<xsd:element name="bpf-email-notification" type="bpf-email-notification-type"/>
        <xsd:complexType name="bpf-email-notification-type">
              <xsd:sequence>
                      <xsd:element name="name" type="xsd:string" />
                      <xsd:element name="description" type="xsd:string" />
                      <xsd:element name="email" type ="email-type" />
              </xsd:sequence>
        </xsd:complexType>
        
        <xsd:complexType name="email-type">
              <xsd:sequence>
                    <xsd:element name="from" type="xsd:string"/>
                    <xsd:element name="to" type="xsd:string" minOccurs="1" maxOccurs="unbounded"/>
              </xsd:sequence>
        </xsd:complexType>    
</xsd:schema>