<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans.dtd">
<beans>

	<bean name="tirDomain"
		class="com.oocl.frm.tir.configuration.SearchDomain">
		<property name="queryParser">
			<bean
				class="com.oocl.frm.tir.search.query.parser.LogicalSizableNGramQueryParser">
				<property name="queryParser">
					<bean
						class="com.oocl.frm.tir.search.query.parser.SizableNGramFuzzyQueryParser">
						<constructor-arg>
							<list>
								<value>1</value>
								<value>4</value>
								<value>9</value>
							</list>
						</constructor-arg>
					</bean>
				</property>
				<property name="separator" value=";"></property>
			</bean>
		</property>

		<property name="requestAdvancedSpec">
			<bean
				class="com.oocl.frm.tir.search.request.RequestAdvancedSpec">
				<property name="sortPolicy" value="Metadata"></property>
				<!--
				<property name="maxHitSize" value="10000"></property>
				-->
				<property name="fetchCount" value="10001"></property>
				<property name="metadatas">
					<list>
						<bean
							class="com.oocl.frm.tir.search.sort.SortMetadata">
							<constructor-arg index="0"
								type="java.lang.String" value="id" />
							<constructor-arg index="1"
								type="java.lang.String" value="long" />
						</bean>
					</list>
				</property>
			</bean>
		</property>

	</bean>

	<bean name="searcherThreadPool"
		class="com.oocl.frm.tir.thread.pool.CachedSearchThreadPool">
	</bean>

	<bean name="userBehaviorLogThreadPool"
		class="com.oocl.frm.tir.thread.pool.UserBehaviorLogThreadPool">
		<constructor-arg value="10"></constructor-arg>
	</bean>

</beans>
