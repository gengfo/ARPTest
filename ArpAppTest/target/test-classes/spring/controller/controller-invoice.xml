<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    
	<!--
		<import resource="../service/service-main.xml"/>
		-->
    
	<bean id="SearchInvoiceController"
		class="com.oocl.ir4.arp.web.invoice.controller.SearchInvoiceController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
	</bean>
    
	<bean id="CreateInvoiceController" 
		class="com.oocl.ir4.arp.web.invoice.controller.CreateInvoiceController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
		<property name="shipmentOpenService" ref="shipmentOpenService"/>
		<property name="invAdjOpenService" ref="invAdjOpenService"/>
		<property name="invAdjService" ref="invAdjService"/>
		<property name="exchangeRateOpenService" ref="exchangeRateOpenService" />
		<property name="currencyService" ref="currencyService" />
		<property name="containerOpenService" ref="containerOpenService" />
		<property name="invoiceService" ref="invoiceService" />
	</bean>
	
	<bean id="containerOpenService" class="com.oocl.ir4.arp.openservice.eqm.impl.DefaultContainerOpenService">
	</bean>
	
	<bean id="updateDueReasonController"
		class="com.oocl.ir4.arp.web.invoice.controller.UpdateDueReasonController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
	</bean>
 
	
    
	<bean id="emailInvoiceController" class="com.oocl.ir4.arp.web.invoice.controller.EmailInvoiceController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
	</bean>
	
	<bean id="faxInvoiceController" class="com.oocl.ir4.arp.web.invoice.controller.FaxInvoiceController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
	</bean>
    
	<bean id="uploadInvoiceController" class="com.oocl.ir4.arp.web.invoice.controller.UploadByInternetController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
		<property name="ruleOpenService" ref="ruleOpenService"/>
	</bean>
    
	<bean id="previewInvoiceController" class="com.oocl.ir4.arp.web.invoice.controller.PreviewInvoiceController">
		<property name="invoiceOpenService" ref="invoiceOpenService"/>
	</bean>
    
</beans>
