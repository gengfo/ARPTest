<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    
	<!--
		<import resource="domain-context.xml" />
		-->
	<bean id="unallocatedCollectionDao" class="com.oocl.ir4.arp.dao.unallocatedcollection.impl.JpaUnallocatedCollectionDao">
	</bean>
    
	<bean id="unallocatedCollectionService" class="com.oocl.ir4.arp.service.unallocatedcollection.DefaultUnallocatedCollectionService">
		<property name="unallocatedCollectionDao" ref="unallocatedCollectionDao"/>
	</bean>
</beans>
